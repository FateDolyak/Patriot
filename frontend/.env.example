# Copy to .env and fill in from the CDK deploy outputs.
# (Vite only exposes vars prefixed with VITE_.)

VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
VITE_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# Hosted UI domain WITHOUT the https:// prefix. Only needed for social login.
# Example: freedom-trail-123456789012.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=
